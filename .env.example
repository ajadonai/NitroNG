# Database (isolated development databases; never point these at shared or production data)
DATABASE_URL="postgresql://nitro:password@127.0.0.1:5432/nitro_dev"
DIRECT_URL="postgresql://nitro:password@127.0.0.1:5432/nitro_dev"
TEST_DATABASE_URL="postgresql://nitro:password@127.0.0.1:5432/nitro_test"

# Destructive local seed (keep the confirmation blank; supply it per command)
NITRO_SEED_DATABASE_NAME="nitro_dev"
# Leave blank here; provide DELETE_LOCAL_SEED_DATA only for the command you intend to run.
NITRO_ALLOW_DESTRUCTIVE_SEED=""
NITRO_SEED_USER_PASSWORD=""
NITRO_SEED_ADMIN_PASSWORD=""

# JWT secrets (change these in production!)
JWT_SECRET="your-user-jwt-secret-here"
JWT_ADMIN_SECRET="your-admin-jwt-secret-here"
# Independent salt for privacy-preserving IP hashes.
IP_HASH_SALT="your-independent-ip-hash-salt-here"
# Optional domain-separated key for 15-minute Pulse/Live grants; defaults to JWT_ADMIN_SECRET.
INTERNAL_DASHBOARD_SECRET=""
# Optional domain-separated key for signed heartbeat presence IDs; defaults to JWT_SECRET.
HEARTBEAT_SECRET=""
# Optional independent read-only analytics credential. Send it only as:
# Authorization: Bearer <ANALYTICS_READ_TOKEN>
ANALYTICS_READ_TOKEN=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
CRON_SECRET="your-cron-secret-here"
ADMIN_EMAIL="admin@example.com"
# Set to 1 only when explicitly validating a production build environment.
NITRO_VALIDATE_PRODUCTION_ENV=""

# Email (Brevo)
BREVO_API_KEY=""
SENDER_EMAIL="noreply@nitro.ng"
SENDER_NAME="Ify from Nitro"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Flutterwave (API keys are DB-managed first; env values are optional fallbacks)
FLUTTERWAVE_PUBLIC_KEY=""
FLUTTERWAVE_SECRET_KEY=""
# Required in production to authenticate incoming webhooks.
FLUTTERWAVE_WEBHOOK_HASH=""

# NOWPayments crypto (API key is DB-managed first; env value is an optional fallback)
NOWPAYMENTS_API_KEY=""
# Required in production to authenticate incoming webhooks.
NOWPAYMENTS_IPN_SECRET=""

# Upstash Redis (required in production; protected routes fail closed if unavailable)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# SMM Providers
MTP_API_URL="https://morethanpanel.com/api/v2"
MTP_API_KEY=""
DAOSMM_API_URL=""
DAOSMM_API_KEY=""
JAP_API_URL=""
JAP_API_KEY=""

# Sentry (all required for production builds; DSN is used at runtime)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
